OPENWEATHER_API_KEY=your_key_here
TOMTOM_API_KEY=your_key_here

# PostgreSQL — used by dbt and applications on the host machine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_city
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Airbyte — used by setup_airbyte.py and Airflow
# AIRBYTE_PG_HOST must be your machine's LAN IP (e.g. 10.2.12.150), NOT localhost.
# Airbyte sync pods run inside Kubernetes (Kind) and cannot reach the host via localhost.
AIRBYTE_PG_HOST=10.2.x.x
AIRBYTE_URL=http://localhost:8001
AIRBYTE_USERNAME=airbyte
AIRBYTE_PASSWORD=password
