OPENWEATHER_API_KEY=your_key_here
TOMTOM_API_KEY=your_key_here

# PostgreSQL — used by dbt and applications on the host machine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_city
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Airbyte — used by setup_airbyte.py and Airflow
# AIRBYTE_PG_HOST is the address Airbyte's destination dials to reach Postgres. It must be
# this machine's LAN IP, NOT localhost — sync pods run inside Kubernetes (Kind) and cannot
# reach the host via localhost.
#   auto  → detect the LAN IP of the default-route interface (recommended; the IP changes
#           whenever you join a different network, so re-running setup_airbyte.py after a
#           switch re-points the destination with no edit here)
#   an IP → pin it explicitly (e.g. 10.2.12.150); overrides detection
AIRBYTE_PG_HOST=auto
AIRBYTE_URL=http://localhost:8001
AIRBYTE_USERNAME=airbyte
AIRBYTE_PASSWORD=password

# Email alerts — Airflow reads AIRFLOW__SMTP__* straight from env (injected via
# docker-compose env_file). For Gmail, SMTP_PASSWORD is a 16-char App Password
# (Google Account → Security → 2-Step Verification → App passwords), NOT your login.
# ALERT_EMAIL takes one address or several comma-separated — all get every alert.
ALERT_EMAIL=you@example.com,teammate@example.com
# Optional — timezone for the "Completed"/"Failed at" line in alert emails.
# Defaults to Europe/Skopje; UTC fallback if the container has no tz database.
ALERT_TZ=Europe/Skopje
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_USER=you@example.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_16_char_app_password
AIRFLOW__SMTP__SMTP_MAIL_FROM=you@example.com
